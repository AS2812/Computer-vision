AGROVISION_API_URL=http://localhost:8765
VITE_API_URL=http://localhost:8765
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DEMO_EMAIL=demo@agrovision.local
SUPABASE_DEMO_PASSWORD=agrovision-local-demo
AGROVISION_DISEASE_MODEL_URL=
AGROVISION_BANANA_DISEASE_MODEL_URL=
EXTERNAL_LLM_API_KEY=
EXTERNAL_LLM_API_URL=https://opencode.ai/zen/v1/chat/completions
EXTERNAL_LLM_MODEL=deepseek-v4-flash-free
EXTERNAL_LLM_TIMEOUT_SECONDS=90
EXTERNAL_LLM_MAX_TOKENS=2000
EXTERNAL_LLM_REASONING_EFFORT=low
EXTERNAL_LLM_TEMPERATURE=0.3

# Hosted vision "second opinion" for the tomato diagnosis. It reuses EXTERNAL_LLM_API_KEY
# and EXTERNAL_LLM_API_URL but needs its OWN multimodal model (the chat model above is
# text-only and rejects images). mimo-v2.5-free is image-capable on the free tier.
# Set EXTERNAL_VISION_ENABLED=false to run fully offline on the local model alone.
EXTERNAL_VISION_ENABLED=true
EXTERNAL_VISION_MODEL=mimo-v2.5-free
EXTERNAL_VISION_TIMEOUT_SECONDS=45
EXTERNAL_VISION_MAX_TOKENS=2000
# Average the local ONNX model over a few views for steadier real-field-photo results.
DISEASE_TTA=true
