# AgroVision Egypt — Tomato Edition (web)
#
# The browser only ever talks to Supabase: anonymous Auth + the `analyze` Edge
# Function (the ONLY gateway). No model keys live in the browser. Copy to
# `apps/web/.env` and fill in. The app runs WITHOUT these too — it falls back to
# local-only screening (in-browser ONNX) when Supabase is not configured.

# Supabase project (publishable / anon key — safe to expose; RLS protects data)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: override the analyze Edge Function URL.
# Defaults to ${VITE_SUPABASE_URL}/functions/v1/analyze when unset.
VITE_ANALYZE_FUNCTION_URL=

# Optional: override the crop assistant Edge Function URL.
# Defaults to ${VITE_SUPABASE_URL}/functions/v1/assistant when unset.
VITE_ASSISTANT_FUNCTION_URL=

# Optional compatibility backend. Leave empty for Netlify + Supabase-only hosting.
# Set this to a Render Free FastAPI URL only if you deploy services/api.
VITE_API_URL=

# --- NOT used by the browser. Set these as Supabase Edge Function secrets ---
# (supabase secrets set EXTERNAL_LLM_API_URL=... etc). The AI second opinion key
# stays server-side, inside the Edge Function.
#   EXTERNAL_LLM_API_URL=https://opencode.ai/zen/v1/chat/completions
#   EXTERNAL_LLM_API_KEY=your-key
#   EXTERNAL_LLM_MODEL=deepseek-v4-flash-free
#   EXTERNAL_VISION_MODEL=mimo-v2.5-free
